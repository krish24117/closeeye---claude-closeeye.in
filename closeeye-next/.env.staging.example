# Close Eye V2 — STAGING environment template
# ------------------------------------------------------------------
# Copy to `.env.staging` (git-ignored) and fill with TEST/STAGING values ONLY.
# NEVER put live production keys here. Client vars (NEXT_PUBLIC_*) are compiled
# into the browser bundle — only the Supabase ANON key (public by design) and
# publishable/test keys belong here. All real secrets live in the Supabase
# staging project's Edge Function secrets, NOT in this file.

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://staging.closeeye.in
NEXT_PUBLIC_WHATSAPP_NUMBER=919000221261

# ── Supabase (STAGING branch/project — not the live kghwmiriboavmyswcqnr) ──
NEXT_PUBLIC_SUPABASE_URL=https://<staging-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-key>

# ── Razorpay (TEST mode key only) ──
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_<xxxxx>

# ── Google Maps (browser key, restricted to staging.closeeye.in) ──
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<staging-maps-browser-key>

# ── Optional: analytics/monitoring (staging keys) ──
# NEXT_PUBLIC_POSTHOG_KEY=<staging>
# NEXT_PUBLIC_SENTRY_DSN=<staging-dsn>

# ==================================================================
# SERVER-SIDE SECRETS — do NOT put these here. Set them on the Supabase
# STAGING project → Edge Functions → Secrets (test values):
#   SUPABASE_SERVICE_ROLE_KEY   (staging)
#   RAZORPAY_KEY_SECRET / RAZORPAY_WEBHOOK_SECRET   (test)
#   TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN / TWILIO_WHATSAPP_FROM (sandbox)
#   TWILIO_TEMPLATE_* / TWILIO_WHATSAPP_TEMPLATE_SID
#   RESEND_API_KEY / RESEND_FROM_EMAIL   (test sender)
#   GOOGLE_MAPS_API_KEY   (server key)
#   ANTHROPIC_API_KEY / CLOSEEYE_*_MODEL
#   ADMIN_WHATSAPP / CARE_TEAM_WHATSAPP / CLOSEEYE_AMBULANCE_NUMBER / APP_URL / BROADCAST_SECRET
# ==================================================================
