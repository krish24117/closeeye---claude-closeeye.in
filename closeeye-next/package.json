{
  "name": "closeeye-next",
  "version": "0.1.0",
  "private": true,
  "description": "CloseEye Next — the world's most trusted presence platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report",
    "e2e:update": "playwright test visual --update-snapshots",
    "validate": "playwright test && lhci autorun",
    "sync:understanding": "node scripts/sync-understanding-cases.mjs",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "android:add": "cap add android",
    "ios:add": "cap add ios",
    "android:open": "cap open android",
    "ios:open": "cap open ios",
    "android:run": "cap run android",
    "ios:run": "cap run ios",
    "mobile:assets": "capacitor-assets generate --assetPath assets --iconBackgroundColor #F6F3EC --iconBackgroundColorDark #0E2A1F --splashBackgroundColor #F6F3EC --splashBackgroundColorDark #0E2A1F"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.3",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.2",
    "@supabase/supabase-js": "^2.110.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.4.2",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.474.0",
    "next": "^15.1.7",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@capacitor/android": "^6.2.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@eslint/eslintrc": "^3.2.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.1.7",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
