# CloseEye Next — environment variables
# Copy to .env.local for development. All NEXT_PUBLIC_* values are exposed to the browser.

# Canonical site URL (used for SEO, sitemap, robots, OG tags)
NEXT_PUBLIC_SITE_URL=https://closeeye.in

# WhatsApp number in international format, digits only (country code + number)
NEXT_PUBLIC_WHATSAPP_NUMBER=919000221261
